        {
          "name": "Payment Links",
          "item": [
            {
              "name": "Create payment link",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"merchantId\": 1,\n  \"merchantReferencePaymentId\": \"ORDER-12345\",\n  \"amount\": 99.99,\n  \"merchantMetadataJson\": \"{\\\"orderId\\\":\\\"ORD-001\\\"}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/payment-links/create",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["api", "v1", "integration", "payment-links", "create"]
                },
                "description": "Creates a payment link. Body matches `PaymentLinkRequest` (merchantId, merchantReferencePaymentId, amount >= 0.01, optional merchantMetadataJson). For TEST channel, response `paymentLinkUrl` points to `/test-payment-link.html?paymentId=...&merchantId=...`."
              },
              "response": []
            },
            {
              "name": "Get payment details by id",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/payment-links/{{paymentLinkId}}",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["api", "v1", "integration", "payment-links", "{{paymentLinkId}}"]
                },
                "description": "Returns `PaymentDetailsResponse` for the given payment link id."
              },
              "response": []
            }
          ]
        },
