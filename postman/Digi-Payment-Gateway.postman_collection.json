                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"merchantId\": 1,\n  \"merchantReferencePaymentId\": \"ORDER-12345\",\n  \"amount\": 99.99,\n  \"merchantMetadataJson\": \"{\\\"orderId\\\":\\\"ORD-001\\\"}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/integration/api/v1/payment-links/create",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["integration", "api", "v1", "payment-links", "create"]
                },
                "description": "Creates a payment link. Body matches `PaymentLinkRequest` (merchantId, merchantReferencePaymentId, amount ≥ 0.01, optional merchantMetadataJson). Currency is taken from `merchant_config` for the merchant."
              },
              "response": []
            },
            {
              "name": "Get payment details by id",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
