              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": { "mode": "raw", "raw": "{}" },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
                },
                "description": "501 Not Implemented."
              },
              "response": []
            },
            {
              "name": "Delete merchant",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
                },
                "description": "Deactivates merchant via `MerchantService`."
              },
              "response": []
            },
            {
              "name": "Create payment channel config",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"paymentChannelId\": 1,\n  \"paymentChannelName\": \"TEST\",\n  \"configJson\": \"{}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}/payment-channel-configs",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants", "{{merchantId}}", "payment-channel-configs"]
                },
                "description": "`dto.MerchantPaymentChannelConfigCreateRequest`: required `paymentChannelId`; optional `paymentChannelName` (`PaymentChannelNameEnum`: XPLORPAY, PAYMOB, STRIPE, RAZORPAY, TEST); optional `configJson`. Server sets active config."
              },
