{
  "info": {
    "_postman_id": "d4c8e2a0-9b1f-4e2d-8c7a-digi-payment-gateway",
    "name": "Digi Payment Gateway",
    "description": "Digi Payment Gateway — REST collection aligned with the Spring Boot app.\n\n**Integration** (`/api/v1/integration/**`): Send `X-API-Key` (merchant API key). `integration.security.ApiKeyAuthenticationFilter` resolves the merchant; do **not** send `merchantId` in the payment-link body. Optional prefix override: `security.integration.path-prefix` (default `/api/v1/integration/`). Response DTOs live in `integration.dto`.\n\n**Portal** (`/api/v1/portal/**`): Send `Authorization: Bearer {{accessToken}}` except **signup** `POST /api/v1/portal/users` (public). Controllers: `controller.portal`.\n\n**Auth** (`/api/v1/auth/**`): Login, email/mobile OTP, refresh, logout — public (no Bearer); see `SecurityConfig` and `JwtAuthenticationFilter`.\n\n**Webhooks** (`/webhook/**`): No API key or JWT (permit-all); production should add signature verification.\n\nDefault `baseUrl`: `http://localhost:8080`. Set `{{apiKey}}` from `MerchantRegistrationResponse` after creating a merchant.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "apiKey", "value": "your-merchant-api-key" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "paymentId", "value": "1" },
    { "key": "merchantId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "configId", "value": "1" }
  ],
  "item": [
    {
      "name": "Integration API",
      "description": "Third-party server-to-server API. `integration.security.ApiKeyAuthenticationFilter` runs before `integration.controller.*` handlers. JWT is not used on these paths.",
      "item": [
        {
          "name": "Payment link",
          "item": [
            {
              "name": "Generate payment link",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"merchantReferencePaymentId\": \"ORDER-12345\",\n  \"amount\": 99.99,\n  \"merchantMetadataJson\": \"{\\\"orderId\\\":\\\"ORD-001\\\"}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/payment-link/generate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "payment-link", "generate"]
                },
                "description": "`integration.controller.PaymentLinkIntegrationController`. Body: `integration.dto.PaymentLinkRequest` (merchantReferencePaymentId, amount ≥ 0.01, optional merchantMetadataJson). Merchant from `X-API-Key` only. 201 + `integration.dto.PaymentLinkResponse`. TEST adapter URLs look like `http://localhost:8080/test-payment-link.html?paymentId=...&merchantId=...`."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Transactions",
          "item": [
            {
              "name": "List transactions",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/transactions",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "transactions"]
                },
                "description": "`integration.controller.TransactionIntegrationController`. Returns `List<integration.dto.PaymentDetailsResponse>` for the merchant from the API key."
              },
              "response": []
            },
            {
              "name": "Get payment details by id",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/transactions/{{paymentId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "transactions", "{{paymentId}}"]
                },
                "description": "`integration.dto.PaymentDetailsResponse` for `id`, scoped to the merchant from the API key."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Terminal payment",
          "item": [
            {
              "name": "Test (placeholder)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/terminal-payment/test",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "terminal-payment", "test"]
                },
                "description": "`integration.controller.TerminalPaymentIntegrationController` placeholder; returns plain text."
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Payment channel webhooks",
      "description": "Inbound provider callbacks. Not under `/api/v1`. Handler: `integration.webhooks.PaymentChannelWebhookController`.",
      "item": [
        {
          "name": "TEST webhook (success)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"SUCCESS\",\n  \"paymentId\": {{paymentId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/v1/payment-channel-webhooks/test",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "v1", "payment-channel-webhooks", "test"]
            },
            "description": "`integration.adapter.TestPaymentChannelAdapter.validateAndParseWebhook`. Body: `paymentStatus` (`PaymentStatusEnum`: INITIATED, PAYMENT_LINK_GENERATED, SUCCESS, FAILED, REFUNDED, VOIDED), numeric `paymentId`. Response: `integration.dto.adaptor.AdaptorWebhookResponse`."
          },
          "response": []
        },
        {
          "name": "TEST webhook (failed)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"FAILED\",\n  \"paymentId\": {{paymentId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/v1/payment-channel-webhooks/test",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "v1", "payment-channel-webhooks", "test"]
            },
            "description": "Same handler with FAILED status sample."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Portal & auth",
      "description": "First-party portal (`/api/v1/portal/**`) and authentication (`/api/v1/auth/**`).",
      "item": [
        {
          "name": "Auth",
          "description": "`auth.controller.AuthController`. No Bearer on these routes (`JwtAuthenticationFilter` skips them). OTP is logged in dev; not sent by email or SMS.",
          "item": [
            {
              "name": "Login (email)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login"]
                },
                "description": "`auth.dto.AuthLoginRequest` → `AuthLoginResponse`. Copy `accessToken` / `refreshToken` into collection variables."
              },
              "response": []
            },
            {
              "name": "Login email — request OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login/email/request-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login", "email", "request-otp"]
                },
                "description": "`auth.dto.AuthEmailOtpRequest`. Dev: OTP is logged server-side, not emailed."
              },
              "response": []
            },
            {
              "name": "Login email — verify OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login/email/verify-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login", "email", "verify-otp"]
                },
                "description": "`auth.dto.AuthEmailVerifyOtpRequest` (6-digit otp). Returns `AuthLoginResponse` with tokens."
              },
              "response": []
            },
            {
              "name": "Login mobile — request OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"mobileNumber\": \"+14155552671\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login/mobile/request-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login", "mobile", "request-otp"]
                },
                "description": "`auth.dto.AuthMobileOtpRequest` (E.164). Returns `AuthOtpRequestResponse`."
              },
              "response": []
            },
            {
              "name": "Login mobile — verify OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"mobileNumber\": \"+14155552671\",\n  \"otp\": \"123456\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login/mobile/verify-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login", "mobile", "verify-otp"]
                },
                "description": "`auth.dto.AuthMobileVerifyOtpRequest`. Returns `AuthLoginResponse`."
              },
              "response": []
            },
            {
              "name": "Refresh token",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "refresh-token"]
                },
                "description": "`auth.dto.AuthRefreshRequest`. Returns new `AuthLoginResponse`."
              },
              "response": []
            },
            {
              "name": "Logout",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/logout",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "logout"]
                },
                "description": "`auth.dto.AuthLogoutRequest`. 204 No Content; refresh token invalidated."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Users",
          "description": "`controller.portal.UserController` — `/api/v1/portal/users`.",
          "item": [
            {
              "name": "Create user",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"New User\",\n  \"mobileNumber\": \"+14155552671\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users"]
                },
                "description": "`dto.UserCreateRequest` (mobileNumber optional; E.164 if set). Public — no Bearer."
              },
              "response": []
            },
            {
              "name": "List users",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users"]
                },
                "description": "No `@GetMapping` on `/users` (list is commented out in `UserController`) — expect **404**, not 501."
              },
              "response": []
            },
            {
              "name": "Get user",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users", "{{userId}}"]
                },
                "description": "`AuthService.assertAuthenticatedUserOwnsUserId` — principal must match `userId`. Returns `UserResponse`."
              },
              "response": []
            },
            {
              "name": "Patch user",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users", "{{userId}}"]
                },
                "description": "`dto.UserUpdateRequest` (self-only). Returns `UserResponse`."
              },
              "response": []
            },
            {
              "name": "Reactivate user",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users/{{userId}}/reactivate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users", "{{userId}}", "reactivate"]
                },
                "description": "`POST .../users/{userId}/reactivate` — self-only; `UserService.reactivateUser` → `UserResponse`."
              },
              "response": []
            },
            {
              "name": "Delete user",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "users", "{{userId}}"]
                },
                "description": "Soft-deactivates user via `UserService`."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Merchants",
          "description": "`controller.portal.MerchantController` — `/api/v1/portal/merchants`.",
          "item": [
            {
              "name": "Create merchant",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Acme Corp\",\n  \"currency\": \"USD\",\n  \"webhookUrl\": \"https://merchant.example/hooks\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants"]
                },
                "description": "`dto.MerchantRegistrationRequest` (currency optional ISO 4217; webhookUrl optional). Returns `MerchantRegistrationResponse` including **apiKey** for integration — save to `{{apiKey}}`. Requires Bearer."
              },
              "response": []
            },
            {
              "name": "List merchants",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants"]
                },
                "description": "501 Not Implemented."
              },
              "response": []
            },
            {
              "name": "Get merchant",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
