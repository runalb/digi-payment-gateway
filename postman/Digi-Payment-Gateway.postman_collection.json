                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["integration", "api", "v1", "payment-links", "{{paymentLinkId}}"]
                },
                "description": "Returns `PaymentDetailsResponse` for the given payment link id."
              },
              "response": []
            }
          ]
        },
