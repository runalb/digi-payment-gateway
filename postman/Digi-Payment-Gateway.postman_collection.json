{
  "info": {
    "_postman_id": "d4c8e2a0-9b1f-4e2d-8c7a-digi-payment-gateway",
    "name": "Digi Payment Gateway",
    "description": "REST endpoints aligned with the Spring Boot app. Integration routes require header `X-API-Key` (merchant API key; merchant is resolved from the key—do not send `merchantId` in `PaymentLinkRequest`). Most `/api/v1/ui/**` routes require `Authorization: Bearer {{accessToken}}` except user signup and auth endpoints (see `SecurityConfig` / `JwtAuthenticationFilter`). Webhooks under `/webhook/**` are permit-all. Default `baseUrl`: `http://localhost:8080`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "apiKey", "value": "your-merchant-api-key" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "paymentId", "value": "1" },
    { "key": "merchantId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "configId", "value": "1" }
  ],
  "item": [
    {
      "name": "Integration API",
      "description": "Authenticated via `ApiKeyAuthenticationFilter`: send `X-API-Key` on every request.",
      "item": [
        {
          "name": "Payment link",
          "item": [
            {
              "name": "Generate payment link",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"merchantReferencePaymentId\": \"ORDER-12345\",\n  \"amount\": 99.99,\n  \"merchantMetadataJson\": \"{\\\"orderId\\\":\\\"ORD-001\\\"}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/payment-link/generate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "payment-link", "generate"]
                },
                "description": "`PaymentLinkIntegrationController`: creates a link. Body is `PaymentLinkRequest` (merchantReferencePaymentId, amount ≥ 0.01, optional merchantMetadataJson). Merchant comes from the API key, not the body. Returns 201 `PaymentLinkResponse`. TEST channel URLs look like `/test-payment-link.html?paymentId=...&merchantId=...`."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Transactions",
          "item": [
            {
              "name": "List transactions",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/transactions",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "transactions"]
                },
                "description": "`TransactionIntegrationController`: returns `List<PaymentDetailsResponse>` for the authenticated merchant."
              },
              "response": []
            },
            {
              "name": "Get payment details by id",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/transactions/{{paymentId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "transactions", "{{paymentId}}"]
                },
                "description": "`TransactionIntegrationController`: `PaymentDetailsResponse` for `id` scoped to the merchant from the API key."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Terminal payment",
          "item": [
            {
              "name": "Test (placeholder)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/integration/terminal-payment/test",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "integration", "terminal-payment", "test"]
                },
                "description": "`TerminalPaymentIntegrationController`: placeholder; returns plain text."
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Payment channel webhooks",
      "description": "No auth. Path prefix `/webhook/v1/payment-channel-webhooks` (not under `/api/v1`).",
      "item": [
        {
          "name": "TEST webhook (success)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"SUCCESS\",\n  \"paymentId\": {{paymentId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/v1/payment-channel-webhooks/test",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "v1", "payment-channel-webhooks", "test"]
            },
            "description": "`PaymentChannelWebhookController` → `TestPaymentChannelAdapter.validateAndParseWebhook`: requires `paymentStatus` (`PaymentStatusEnum`: INITIATED, PAYMENT_LINK_GENERATED, SUCCESS, FAILED, REFUNDED, VOIDED) and numeric `paymentId`. Response is `AdaptorWebhookResponse` (status, paymentId, paymentChannelTxnId, merchantReferencePaymentId)."
          },
          "response": []
        },
        {
          "name": "TEST webhook (failed)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"FAILED\",\n  \"paymentId\": {{paymentId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/v1/payment-channel-webhooks/test",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "v1", "payment-channel-webhooks", "test"]
            },
            "description": "Same handler with FAILED status sample."
          },
          "response": []
        }
      ]
    },
    {
      "name": "UI API",
      "item": [
        {
          "name": "Auth",
          "description": "No Bearer required on these routes (JWT filter skips them).",
          "item": [
            {
              "name": "Login (email)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "auth", "login"]
                },
                "description": "`AuthLoginRequest` → `AuthLoginResponse`. Copy `accessToken` / `refreshToken` into collection variables if needed."
              },
              "response": []
            },
            {
              "name": "Login mobile — request OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"mobileNumber\": \"+14155552671\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/auth/login/mobile/request-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "auth", "login", "mobile", "request-otp"]
                },
                "description": "`AuthMobileOtpRequest` (E.164 mobile). Returns `AuthOtpRequestResponse`."
              },
              "response": []
            },
            {
              "name": "Login mobile — verify OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"mobileNumber\": \"+14155552671\",\n  \"otp\": \"123456\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/auth/login/mobile/verify-otp",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "auth", "login", "mobile", "verify-otp"]
                },
                "description": "`AuthMobileVerifyOtpRequest` (6-digit otp)."
              },
              "response": []
            },
            {
              "name": "Refresh token",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/auth/refresh",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "auth", "refresh"]
                },
                "description": "`AuthRefreshRequest`."
              },
              "response": []
            },
            {
              "name": "Logout",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/auth/logout",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "auth", "logout"]
                },
                "description": "`AuthLogoutRequest`. 204 No Content."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Users",
          "item": [
            {
              "name": "Create user",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"New User\",\n  \"mobileNumber\": \"+14155552671\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/users",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "users"]
                },
                "description": "`UserCreateRequest` (mobileNumber optional; E.164 if set). Public (no Bearer)."
              },
              "response": []
            },
            {
              "name": "List users",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/users",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "users"]
                },
                "description": "Currently returns 501 Not Implemented."
              },
              "response": []
            },
            {
              "name": "Get user",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "users", "{{userId}}"]
                },
                "description": "501 Not Implemented."
              },
              "response": []
            },
            {
              "name": "Patch user",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "users", "{{userId}}"]
                },
                "description": "501 Not Implemented; body is generic JSON map in controller."
              },
              "response": []
            },
            {
              "name": "Delete user",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "users", "{{userId}}"]
                },
                "description": "Soft-deactivates user via `UserService`."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Merchants",
          "item": [
            {
              "name": "Create merchant",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Acme Corp\",\n  \"currency\": \"USD\",\n  \"webhookUrl\": \"https://merchant.example/hooks\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/ui/merchants",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "ui", "merchants"]
                },
                "description": "`MerchantRegistrationRequest` (currency optional 3-letter ISO 4217; webhookUrl optional). Requires Bearer per security rules."
              },
              "response": []
            },
            {
              "name": "List merchants",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
