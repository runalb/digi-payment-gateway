    {
      "name": "Merchants (portal)",
      "description": "`merchant.controller.MerchantController` — `/api/v1/portal/merchants`. All routes require Bearer; merchant ownership enforced where applicable.",
      "item": [
        {
          "name": "Create merchant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"billing@acme.example\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants"]
            },
            "description": "`MerchantCreateRequest` — `name`, `email`. 201 + `MerchantResponse` including **apiKey** — save to `{{apiKey}}` for integration calls."
          },
          "response": []
        },
        {
          "name": "List merchants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants"]
            },
            "description": "Merchants for the authenticated user — `List<MerchantResponse>`."
          },
          "response": []
        },
        {
          "name": "Get merchant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
            },
            "description": "`MerchantResponse` — must own merchant."
          },
          "response": []
        },
        {
          "name": "Patch merchant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Ltd\",\n  \"email\": \"newemail@acme.example\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
            },
            "description": "`MerchantUpdateRequest` — all fields optional."
          },
          "response": []
        },
        {
          "name": "Delete merchant (deactivate)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}"]
            },
            "description": "204 No Content."
          },
          "response": []
        },
        {
          "name": "Get merchant config",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}", "config"]
            },
            "description": "`MerchantConfigResponse`."
          },
          "response": []
        },
        {
          "name": "Create merchant config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"USD\",\n  \"webhookUrl\": \"https://merchant.example/hooks\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}", "config"]
            },
            "description": "`MerchantConfigCreateRequest` — required 3-letter ISO 4217 `currency`; `webhookUrl` optional. Returns 200 in current controller implementation."
          },
          "response": []
        },
        {
          "name": "Patch merchant config",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"EUR\",\n  \"webhookUrl\": \"https://merchant.example/v2/hooks\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/portal/merchants/{{merchantId}}/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "portal", "merchants", "{{merchantId}}", "config"]
            },
            "description": "`MerchantConfigUpdateRequest` — fields optional."
          },
          "response": []
        },
        {
          "name": "Create payment channel config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentChannelId\": 1,\n  \"paymentChannelName\": \"TEST\",\n  \"configJson\": \"{}\"\n}"
