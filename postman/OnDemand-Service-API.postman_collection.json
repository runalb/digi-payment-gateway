              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "catalog", "categories"]
            },
            "description": "`List<CatalogCategoryResponse>`."
          },
          "response": []
        },
        {
          "name": "Get category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
