              "path": [
                "api",
                "v1",
                "portal",
                "merchants",
                "{{merchantId}}",
                "payment-channel-configs",
                "{{configId}}"
              ]
            },
            "description": "204 No Content."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Catalog",
      "description": "`catalog.controller.CatalogController` — `/api/v1/catalog`. **GET** requires authentication. **POST/PATCH/DELETE** require `SUPER_ADMIN` role.",
